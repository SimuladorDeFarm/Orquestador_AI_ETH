# Dani-ETH — variables de entorno de ejemplo.
# Copia este archivo a .env y completa los valores:  cp .env.example .env
# (el .env real está en .gitignore: NUNCA lo subas al repositorio).

# --- DeepSeek (requerida) ---
# API key de DeepSeek. El nombre de la variable es 'Deepseek' (lo lee config.py).
Deepseek=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Runner (servicio externo que ejecuta las herramientas) ---
# Opcionales: si se omiten, se usan estos mismos valores por defecto.
RUNNER_REGISTRY_URL=http://127.0.0.1:8003
RUNNER_EXECUTOR_URL=http://127.0.0.1:8004

# --- Sesión del runner ---
# Opcional. Sesión única por ahora (default: 3).
SESION_ID=3

# --- CORS ---
# Opcional. Orígenes del frontend autorizados a llamar a la API desde el navegador.
# Lista separada por comas. Default: puertos típicos de Vite en desarrollo.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
